{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "regions": ["fra1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/mpp/employee/balance/stream/route.ts": {
      "maxDuration": 60
    },
    "app/api/demo/run-agent/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/process-expired-escrows/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/process-reputation-writes/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/autopayroll-tick/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/index-virtual-inflows/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-expired-escrows",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/process-reputation-writes",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/autopayroll-tick",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/index-virtual-inflows",
      "schedule": "*/30 * * * *"
    }
  ]
}
