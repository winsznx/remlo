{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Remlo",
  "theme": "mint",
  "description": "Borderless enterprise payroll on Tempo L1.",
  "colors": {
    "primary": "#059669",
    "light": "#34D399",
    "dark": "#064E3B"
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "logo": {
    "dark": "/docs/logo-dark.svg",
    "light": "/docs/logo-light.svg",
    "href": "https://docs.remlo.xyz"
  },
  "favicon": {
    "dark": "/docs/favicon.svg",
    "light": "/docs/favicon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "docs/index",
              "docs/architecture",
              "docs/quickstart"
            ]
          },
          {
            "group": "Protocol",
            "pages": [
              "docs/protocol/contracts",
              "docs/protocol/memo"
            ]
          },
          {
            "group": "On-Chain",
            "pages": [
              "docs/on-chain/payroll-treasury",
              "docs/on-chain/payroll-batcher",
              "docs/on-chain/employee-registry",
              "docs/on-chain/stream-vesting",
              "docs/on-chain/yield-router"
            ]
          },
          {
            "group": "MPP API",
            "pages": [
              "docs/mpp-api/overview",
              "docs/mpp-api/authentication",
              "docs/mpp-api/yield-rates",
              "docs/mpp-api/payroll-execution",
              "docs/mpp-api/compliance-check",
              "docs/mpp-api/salary-advance",
              "docs/mpp-api/salary-stream",
              "docs/mpp-api/payment-history",
              "docs/mpp-api/payslip",
              "docs/mpp-api/memo-decode",
              "docs/mpp-api/bridge-off-ramp",
              "docs/mpp-api/treasury-optimize",
              "docs/mpp-api/treasury-session",
              "docs/mpp-api/compliance-marketplace"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "docs/integrations/bridge",
              "docs/integrations/privy",
              "docs/integrations/agentcash",
              "docs/integrations/vincent"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "docs/operations/environment-variables",
              "docs/operations/deployment",
              "docs/operations/contract-deployment"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://remlo.xyz"
      },
      {
        "label": "Status",
        "href": "https://remlo.xyz/status"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://remlo.xyz"
    }
  }
}
