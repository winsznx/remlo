{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Remlo",
  "description": "Global payroll, treasury, cards, and machine-paid workflows on Tempo.",
  "colors": {
    "primary": "#22C55E",
    "light": "#6EE7B7",
    "dark": "#15803D"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "logo": {
    "light": "/docs/logo-light.svg",
    "dark": "/docs/logo-dark.svg",
    "href": "https://docs.remlo.xyz"
  },
  "favicon": {
    "light": "/docs/favicon.svg",
    "dark": "/docs/favicon.svg"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    },
    "icons": {
      "library": "lucide"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "docs/index",
              "docs/quickstart",
              "docs/architecture"
            ]
          },
          {
            "group": "Workspaces",
            "pages": [
              "docs/platform/auth-and-access",
              "docs/platform/employer-dashboard",
              "docs/platform/employee-portal"
            ]
          },
          {
            "group": "Protocol and Integrations",
            "pages": [
              "docs/protocol/contracts",
              "docs/protocol/memo-and-compliance",
              "docs/integrations/bridge",
              "docs/integrations/privy"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "docs/operations/environment-variables",
              "docs/operations/deployment"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "APIs and Webhooks",
            "pages": [
              "docs/reference/core-rest-api",
              "docs/reference/mpp-endpoints",
              "docs/reference/webhooks-and-demo-agent"
            ]
          },
          {
            "group": "Surface Map",
            "pages": [
              "docs/reference/web-routes"
            ]
          }
        ]
      }
    ],
    "anchors": [
      {
        "name": "App",
        "url": "https://remlo.xyz",
        "icon": "panel-top-open"
      },
      {
        "name": "Status",
        "url": "https://remlo.xyz/status",
        "icon": "activity"
      },
      {
        "name": "Contact",
        "url": "https://remlo.xyz/contact",
        "icon": "mail"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Pricing",
        "href": "https://remlo.xyz/pricing"
      },
      {
        "label": "Status",
        "href": "https://remlo.xyz/status"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://remlo.xyz"
    }
  }
}
